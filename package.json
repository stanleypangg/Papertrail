{
  "name": "papertrail",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "cache:demo-narration": "pnpm dlx tsx scripts/cache-demo-narration.ts",
    "tunnel:cloudflare": "pnpm dlx cloudflared tunnel --url http://localhost:3000",
    "build": "next build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:push": "drizzle-kit push"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "sharp",
      "unrs-resolver"
    ]
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/xr": "^6.6.29",
    "@sparkjsdev/spark": "^2.0.0",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.562.0",
    "next": "^16.2.4",
    "openai": "^6.35.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-qr-code": "^2.0.21",
    "three": "^0.184.0",
    "three-mesh-bvh": "^0.9.9",
    "zod": "^4.1.13",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.0",
    "@vitest/ui": "^4.1.5",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.2.4",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
